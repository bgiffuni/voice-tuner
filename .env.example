# Anthropic API key (https://console.anthropic.com/).
# Optional: if omitted, the app runs in offline DEMO mode — writing samples are
# analyzed with a local heuristic instead of Claude, so you can try the whole
# flow with no key. Set it to use real Claude analysis.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: force a backend. "live" = Claude (needs the key), "demo" = offline.
# Default: live when ANTHROPIC_API_KEY is set, otherwise demo.
# PROVIDER=demo

# Optional: override the model (default claude-opus-4-8).
# MODEL=claude-opus-4-8

# Optional: port to run the server on (default 4344).
# PORT=4344

# Auth: only emails at this domain may sign up. Leave unset to allow any email.
# ALLOWED_EMAIL_DOMAIN=gonemo.ai

# Auth: secret used to sign session cookies. Set a long random value in
# production so sessions survive restarts. If unset, a random secret is
# generated and stored in data/.session-secret.
# SESSION_SECRET=change-me-to-a-long-random-string

# Auth: set to 1 when served over HTTPS (production) so cookies are marked Secure.
# SECURE_COOKIES=1

# Optional: directory for runtime data (users + saved styles). Default ./data.
# DATA_DIR=./data

# Password-reset email. Pick ONE backend (or neither — then reset links are just
# logged to the server console, handy for local testing).
#
# Option A — SMTP (e.g. Google Workspace / Gmail). Takes priority if SMTP_HOST
# is set. For Gmail, SMTP_PASS must be a Google "App Password", and
# RESET_EMAIL_FROM should match SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gonemo.ai
# SMTP_PASS=your-16-char-app-password
#
# Option B — Resend (https://resend.com). Used if SMTP_HOST is unset.
# RESEND_API_KEY=re_...
#
# The visible sender (any backend). Match your authenticated SMTP user for Gmail.
# RESET_EMAIL_FROM=Voice Tuner <noreply@gonemo.ai>

# Optional: public URL used to build reset links. If unset, it's derived from
# the request (works behind an HTTPS proxy). Set it if links come out wrong.
# APP_URL=https://your-app.onrender.com
